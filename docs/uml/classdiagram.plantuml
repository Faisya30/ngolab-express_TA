erDiagram
    COMPANY ||--o{ USER : memiliki
    COMPANY ||--o{ COMPANY_PRODUCT : memiliki_akses
    PRODUCT ||--o{ COMPANY_PRODUCT : diberikan_ke
    USER ||--o{ ACTIVATION_TOKEN : memiliki
    USER ||--o{ USER_ROLE : memiliki
    ROLE ||--o{ USER_ROLE : diberikan
    ROLE ||--o{ ROLE_PERMISSION : memiliki
    PERMISSION ||--o{ ROLE_PERMISSION : digunakan

    COMPANY {
        int company_id PK
        string company_name
        string address
        string phone
        string email
        string status
        datetime created_at
        datetime updated_at
    }

    USER {
        int user_id PK
        int company_id FK
        string full_name
        string email
        string password
        string status
        datetime created_at
        datetime updated_at
    }

    PRODUCT {
        int product_id PK
        string product_name
        string description
        string product_url
        string status
        datetime created_at
        datetime updated_at
    }

    COMPANY_PRODUCT {
        int company_product_id PK
        int company_id FK
        int product_id FK
        string access_status
        datetime assigned_at
    }

    ROLE {
        int role_id PK
        string role_name
        string description
        string status
        datetime created_at
        datetime updated_at
    }

    PERMISSION {
        int permission_id PK
        string permission_name
        string module_name
        string action
        datetime created_at
        datetime updated_at
    }

    USER_ROLE {
        int user_role_id PK
        int user_id FK
        int role_id FK
        datetime assigned_at
    }

    ROLE_PERMISSION {
        int role_permission_id PK
        int role_id FK
        int permission_id FK
        datetime created_at
    }

    ACTIVATION_TOKEN {
        int token_id PK
        int user_id FK
        string token
        string token_type
        datetime expired_at
        string status
        datetime created_at
    }