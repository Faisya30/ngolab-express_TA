@startuml
title Sequence Diagram Gesture Navigation

actor Customer
participant Camera
participant MediaPipe
participant "Kiosk UI" as UI

Customer -> Camera : Melakukan gesture tangan
Camera -> MediaPipe : Mengirim frame kamera

MediaPipe -> MediaPipe : Mendeteksi tangan dan posisi jari
MediaPipe -> MediaPipe : Mengidentifikasi gesture

MediaPipe --> UI : Mengirim hasil gesture

alt Gesture dikenali
    UI -> UI : Menentukan aksi navigasi
    UI -> UI : Memperbarui tampilan menu
    UI --> Customer : Menampilkan perubahan halaman
else Gesture tidak dikenali
    UI --> Customer : Menampilkan instruksi gesture ulang
end

@enduml