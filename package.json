{
  "name": "ngolab-express",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/frontend/apps/admin-app",
    "apps/frontend/apps/user-app",
    "apps/shared-lib",
    "apps/backend",
    "ngolab-express-super-admin"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix apps/backend\" \"npm run dev --prefix apps/frontend/apps/admin-app\" \"npm run dev --prefix apps/frontend/apps/user-app\"",
    "dev:kiosk": "npm run dev --prefix apps/frontend/apps/user-app",
    "dev:admin": "npm run dev --prefix apps/frontend/apps/admin-app",
    "dev:user": "npm run dev --prefix apps/frontend/apps/user-app",
    "dev:super-admin": "npm run dev --prefix ngolab-express-super-admin",
    "dev:backend": "npm run dev --prefix apps/backend",
    "build": "npm run build --prefix apps/frontend/apps/admin-app && npm run build --prefix apps/frontend/apps/user-app",
    "preview:admin": "npm run preview --prefix apps/frontend/apps/admin-app",
    "preview:user": "npm run preview --prefix apps/frontend/apps/user-app",
    "lint": "npm run lint --prefix apps/frontend/apps/admin-app && npm run lint --prefix apps/frontend/apps/user-app"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@google/generative-ai": "^0.24.1",
    "@iconify-react/boxicons": "^1.0.2",
    "@iconify-react/mdi": "^1.0.2",
    "@iconify-react/pixelarticons": "^1.0.3",
    "@iconify/react": "^6.0.2",
    "multer": "^2.1.1",
    "tesseract.js": "^7.0.0"
  }
}
